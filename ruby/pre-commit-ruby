#!/bin/bash
# Ruby Pre-Commit Hook

echo "🔍 Running pre-commit checks..."

# Skip if SKIP_HOOKS is set
if [ -n "$SKIP_HOOKS" ]; then
  echo "⏭️  Skipping hooks (SKIP_HOOKS is set)"
  exit 0
fi

# Check if bundle is available
if ! command -v bundle &> /dev/null; then
  echo "⚠️  Bundle not found. Skipping Ruby checks."
  exit 0
fi

# Run RuboCop on staged files
STAGED_RUBY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rb$' || true)

if [ -n "$STAGED_RUBY_FILES" ]; then
  echo "🔎 Running RuboCop on staged files..."
  bundle exec rubocop $STAGED_RUBY_FILES
  
  if [ $? -ne 0 ]; then
    echo "❌ RuboCop found issues. Fix them or use 'git commit --no-verify' to skip."
    exit 1
  fi
fi

# Run RSpec if spec files exist
if [ -d "spec" ]; then
  echo "🧪 Running RSpec unit tests..."
  bundle exec rspec
  
  if [ $? -ne 0 ]; then
    echo "❌ RSpec tests failed. Fix them or use SKIP_HOOKS=1."
    exit 1
  fi
fi

echo "✅ Pre-commit checks passed!"
exit 0